# ============================================================
# 배포 자동화 설정 템플릿
# ============================================================
# 사용 방법:
#   1. 이 파일을 복사해서 .env.local 로 저장
#      cp .env.local.example .env.local
#   2. 아래 값을 채운 뒤 AI에게 "배포해줘" 요청
#
# ⚠️ .env.local 은 GitHub에 올라가지 않습니다 (비밀번호·토큰 보호)
# ============================================================


# ────────────────────────────────────────────────────────────
# GitHub
# ────────────────────────────────────────────────────────────

# Personal Access Token
# 발급: GitHub → Settings → Developer settings → Personal access tokens
# 권한: repo (저장소 생성·코드 push)
GITHUB_TOKEN=

# GitHub 아이디 (또는 Organization 이름)
GITHUB_USERNAME=

# 새로 만들 저장소 이름 (예: motion-project)
# URL: https://github.com/{GITHUB_USERNAME}/{GITHUB_REPO_NAME}
GITHUB_REPO_NAME=

# public | private
GITHUB_REPO_VISIBILITY=public

# 기본 브랜치 (보통 main 그대로 두면 됨)
GITHUB_DEFAULT_BRANCH=main


# ────────────────────────────────────────────────────────────
# Vercel
# ────────────────────────────────────────────────────────────

# API Token
# 발급: Vercel → Account Settings → Tokens → Create Token
VERCEL_TOKEN=

# Vercel 프로젝트 이름 → https://{이름}.vercel.app
VERCEL_PROJECT_NAME=

# 팀 Vercel 계정일 때만 (개인 계정이면 비워두기)
# VERCEL_TEAM_ID=


# ────────────────────────────────────────────────────────────
# 사이트 기본 정보 (선택)
# ────────────────────────────────────────────────────────────

# 브라우저 탭·검색 결과에 보이는 사이트 이름
SITE_TITLE=

# ko | en
SITE_LOCALE=ko

# 커스텀 도메인 (없으면 비워두기)
# CUSTOM_DOMAIN=www.example.com

# 배포 후 공개 URL (자동 입력 — 수정하지 않아도 됨)
# NEXT_PUBLIC_SITE_URL=
